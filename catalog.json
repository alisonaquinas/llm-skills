{
  "marketplace": {
    "name": "llm-skills",
    "title": "Alison's LLM Skills Marketplace",
    "description": "Browse Claude Code and Codex skill bundles for CI/CD, software design, docs, and web dev. Install from GitHub in one command.",
    "version": "1.4.8",
    "owner": {
      "name": "Alison Aquinas"
    },
    "githubRepo": "alisonaquinas/llm-skills",
    "githubUrl": "https://github.com/alisonaquinas/llm-skills",
    "siteUrl": "https://llm-skills.alisonaquinas.com",
    "marketplaceJsonUrl": "https://llm-skills.alisonaquinas.com/marketplace.json"
  },
  "feedSources": [
    {
      "owner": "alisonaquinas",
      "repo": "llm-skills",
      "label": "Marketplace",
      "ref": "main",
      "enabled": true
    },
    {
      "owner": "alisonaquinas",
      "repo": "llm-ci-dev",
      "label": "CI/CD Skills",
      "ref": "main",
      "enabled": true
    },
    {
      "owner": "alisonaquinas",
      "repo": "llm-shared-skills",
      "label": "Shared Skills",
      "ref": "main",
      "enabled": true
    },
    {
      "owner": "alisonaquinas",
      "repo": "llm-software-design",
      "label": "Software Design Skills",
      "ref": "main",
      "enabled": true
    },
    {
      "owner": "alisonaquinas",
      "repo": "llm-doc-skills",
      "label": "Doc Skills",
      "ref": "main",
      "enabled": true
    },
    {
      "owner": "alisonaquinas",
      "repo": "llm-web-design-skills",
      "label": "Web Design Skills",
      "ref": "main",
      "enabled": true
    }
  ],
  "plugins": [
    {
      "pluginName": "shared-skills",
      "owner": "alisonaquinas",
      "repo": "llm-shared-skills",
      "label": "Shared Skills",
      "category": "shared-skills",
      "color": "bg-blue-100 text-blue-800",
      "icon": "🧰",
      "ref": "v1.8.0",
      "version": "1.8.0",
      "siteDescription": "Reusable Claude Code and Codex skills for common developer workflows and shared utilities."
    },
    {
      "pluginName": "ci-cd",
      "owner": "alisonaquinas",
      "repo": "llm-ci-dev",
      "label": "CI/CD Skills",
      "category": "ci-cd",
      "color": "bg-emerald-100 text-emerald-800",
      "icon": "🚀",
      "ref": "v1.2.4",
      "version": "1.2.4",
      "siteDescription": "Claude Code and Codex skills focused on CI/CD pipelines, release flows, and delivery automation."
    },
    {
      "pluginName": "software-design",
      "owner": "alisonaquinas",
      "repo": "llm-software-design",
      "label": "Software Design Skills",
      "category": "software-design",
      "color": "bg-amber-100 text-amber-800",
      "icon": "🏛️",
      "ref": "v1.4.3",
      "version": "1.4.3",
      "siteDescription": "Claude Code and Codex skills focused on software design, OOP, architecture, and maintainability guidance."
    },
    {
      "pluginName": "doc-skills",
      "owner": "alisonaquinas",
      "repo": "llm-doc-skills",
      "label": "Doc Skills",
      "category": "doc-skills",
      "color": "bg-violet-100 text-violet-800",
      "icon": "📄",
      "ref": "v1.3.1",
      "version": "1.3.1",
      "siteDescription": "Claude Code and Codex skills for creating and editing Word, PowerPoint, Excel, and PDF documents."
    },
    {
      "pluginName": "web-design-skills",
      "owner": "alisonaquinas",
      "repo": "llm-web-design-skills",
      "label": "Web Design Skills",
      "category": "web-design-skills",
      "color": "bg-cyan-100 text-cyan-800",
      "icon": "🌐",
      "ref": "v1.1.5",
      "version": "1.1.5",
      "siteDescription": "Claude Code and Codex skills for web design, UI/UX, CSS, HTML, and front-end development workflows."
